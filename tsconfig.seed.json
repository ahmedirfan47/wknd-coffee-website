{
  "compilerOptions": {
    "module":           "CommonJS",
    "target":           "ES2020",
    "lib":              ["ES2020"],
    "strict":           false,
    "esModuleInterop":  true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir":           "dist",
    "skipLibCheck":     true
  },
  "include": ["prisma/**/*.ts"]
}